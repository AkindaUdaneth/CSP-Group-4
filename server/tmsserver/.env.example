# Backend local dev environment (DO NOT commit real .env)
#
# Copy to .env and fill values:
#   cp .env.example .env
#
# JWT__KEY is read as Jwt:Key by ASP.NET Core config binding.

# Azure SQL / DB
AZURE_SQL_CONNECTIONSTRING="Server=tcp:YOUR_SERVER.database.windows.net,1433;Initial Catalog=YOUR_DB;Persist Security Info=False;User ID=YOUR_USER;Password=YOUR_PASSWORD;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"

# JWT
JWT__KEY="CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS"

# Optional: CORS origins as JSON array (or set via appsettings.*)
# Cors__AllowedOrigins__0="http://localhost:5173"

